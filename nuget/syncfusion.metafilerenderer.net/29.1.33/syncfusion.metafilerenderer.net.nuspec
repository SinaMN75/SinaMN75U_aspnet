    <icon>syncfusion_logo.png</icon>
    <projectUrl>https://www.syncfusion.com/?utm_source=nuget&amp;utm_medium=listing</projectUrl>
    <description>The Metafile Renderer is a .NET library used by Syncfusion® Document Processing Libraries for converting the Metafile (EMF and WMF) to SKBitmap image in any .NET applications.</description>
    <releaseNotes>https://ej2.syncfusion.com/aspnetcore/documentation/release-notes/29.1.33?utm_source=nuget&amp;utm_medium=listing</releaseNotes>
