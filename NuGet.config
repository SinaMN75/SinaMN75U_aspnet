<?xml version="1.0" encoding="utf-8"?>

<configuration>
    <packageSources>
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
        <add key="LocalSyncfusion" value="./nuget" />
    </packageSources>
    <packageSourceMapping>
        <packageSource key="LocalSyncfusion">
            <package pattern="Syncfusion.*" />
        </packageSource>
        <packageSource key="nuget.org">
            <package pattern="*" />
        </packageSource>
    </packageSourceMapping>
</configuration>