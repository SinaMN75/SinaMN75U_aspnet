### =====================================================================
### Hotel API  (base route: api/Hotel/)
### Sub-resources: Hotel, HotelRoom, Dorm, DormRoom, DormBed, DormBedContract, DormBedInvoice
### Tags -> TagHotel:101 | TagRoom:101 Single,102 Double,103 Triple
###         TagDorm:101 Girls,102 Boys | TagDormRoom:101 Single,102 Double,103 Dorm
###         TagDormBed:101 Single,102 Double | TagDormBedContract:103 Monthly ...
###         TagDormBedInvoice:102 Rent,204 NotPaid ...
### =====================================================================
@host = http://localhost:5000
@apiKey = your-dev-api-key
@token =

### ---------------- Hotel ----------------

### Hotel/Create
POST {{host}}/api/Hotel/Hotel/Create
Content-Type: application/json

{
  "apiKey": "{{apiKey}}",
  "token": "{{token}}",
  "title": "Grand Hotel",
  "cityCode": "021",
  "tags": [101]
}

### Hotel/Read
POST {{host}}/api/Hotel/Hotel/Read
Content-Type: application/json

{
  "apiKey": "{{apiKey}}",
  "token": "{{token}}",
  "cityCode": "021",
  "pageSize": 20,
  "pageNumber": 1,
  "selectorArgs": {}
}

### Hotel/ReadById
POST {{host}}/api/Hotel/Hotel/ReadById
Content-Type: application/json

{
  "apiKey": "{{apiKey}}",
  "token": "{{token}}",
  "id": "00000000-0000-0000-0000-000000000000",
  "selectorArgs": {}
}

### Hotel/Update
POST {{host}}/api/Hotel/Hotel/Update
Content-Type: application/json

{
  "apiKey": "{{apiKey}}",
  "token": "{{token}}",
  "id": "00000000-0000-0000-0000-000000000000",
  "title": "Grand Hotel (renovated)"
}

### Hotel/Delete
POST {{host}}/api/Hotel/Hotel/Delete
Content-Type: application/json

{
  "apiKey": "{{apiKey}}",
  "token": "{{token}}",
  "id": "00000000-0000-0000-0000-000000000000"
}

